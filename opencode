#!/bin/bash
#
# opencode-cli - Run opencode in a container via podman-compose
#
# This script provides a convenient CLI wrapper around opencode, running it inside
# a Docker/Podman container instead of directly on the host system. This provides:
# - Isolation from the host system's environment
# - Consistent experience across different machines
# - Easy setup without installing dependencies globally
#
# Usage (add to PATH for global use):
#   opencode                        # Start in current directory
#   opencode git --version          # Run git in container
#   PROJECT_DIR=/path/to/project    # Run in specific project
#


# Set the project directory to the current working directory if not explicitly specified
# This determines where opencode will look for files and where mounted volumes point
export PROJECT_DIR="${PROJECT_DIR:-$PWD}"
export BASE_DIR="${PROJECT_DIR}"

# Get the directory where this script is located
# This allows the script to be run from anywhere (e.g., symlinked to PATH)
# dirname and BASH_SOURCE handle symlinks correctly to find the actual script location
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Parse extra volume mounts from .opencode-mounts in the project directory
# Format per line: HOST_PATH:CONTAINER_PATH:MOUNT_OPTIONS
# Lines starting with # and empty lines are skipped
MOUNTS_FILE="$PROJECT_DIR/.opencode-mounts"
EXTRA_ARGS=()

if [ -f "$MOUNTS_FILE" ]; then
    while IFS= read -r line || [ -n "$line" ]; do
        line="${line#"${line%%[![:space:]]*}"}"
        [ -z "$line" ] && continue
        [ "${line#\#}" != "$line" ] && continue
        host_path="${line%%:*}"
        rest="${line#*:}"
        container_path="${rest%%:*}"
        mount_opts="${rest#*:}"
        host_path="${host_path/#\~/$HOME}"
        EXTRA_ARGS+=(--volume "$host_path:$container_path:$mount_opts")
    done < "$MOUNTS_FILE"
fi

# Auto-detect SSH agent socket and forward it into the container
# This allows git push (and other SSH operations) without mounting raw private keys
if [ -n "$SSH_AUTH_SOCK" ]; then
    EXTRA_ARGS+=(--volume "$SSH_AUTH_SOCK:/ssh-agent:ro")
    EXTRA_ARGS+=(--env "SSH_AUTH_SOCK=/ssh-agent")
fi

BUILD=""
BUILD_ARG=""
if [[ "$1" == "build" ]]; then
    BUILD="-build"
    BUILD_ARG="--build"
    echo "Building with $SCRIPT_DIR/docker-compose${BUILD}.yaml file"
fi

# Execute podman-compose with the following options:
# --user $(id -u):$(id -g): Run the container as the current user
# --rm: Remove the container after it exits (clean up)
# --service-ports: Expose ports defined in docker-compose.yaml (e.g., for API access)
# --volume "$PROJECT_DIR:/workspace:Z": Mount the project directory to /workspace in the container
#   The :Z flag ensures proper SELinux labelling for the volume
# opencode: The service name from docker-compose.yaml to run
# "$@": Pass all command-line arguments to the container
export HOST_UID=$(id -u)
export HOST_GID=$(id -g)
exec podman compose --in-pod=false \
    -f $SCRIPT_DIR/docker-compose${BUILD}.yaml run ${BUILD_ARG} \
    --rm --service-ports \
    --volume "$PROJECT_DIR:/workspace:Z" \
    "${EXTRA_ARGS[@]}" opencode "$@"